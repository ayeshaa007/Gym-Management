<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.GymManagement" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary_dark_green</item>
        <item name="colorPrimaryDark">@color/primary_darker_green</item>
        <item name="colorAccent">@color/primary_light_green</item>
        <item name="android:windowBackground">@color/background_gray</item>
    </style>

    <style name="Theme.GymManagement.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Card Style -->
    <style name="CardStyle">
        <item name="android:layout_margin">8dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="android:background">@color/white</item>
    </style>

    <!-- Button Styles -->
    <style name="PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/text_white</item>
        <item name="backgroundTint">@color/primary_dark_green</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:padding">16dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/primary_dark_green</item>
        <item name="strokeColor">@color/primary_dark_green</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:padding">16dp</item>
    </style>

    <!-- Text Input Style -->
    <style name="TextInputStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary_light_green</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Header Text Style -->
    <style name="HeaderText">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Subtitle Text Style -->
    <style name="SubtitleText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_white_80</item>
    </style>

    <!-- Stat Number Style -->
    <style name="StatNumber">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Stat Label Style -->
    <style name="StatLabel">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="PinKeyStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:layout_margin">10dp</item>
        <item name="android:layout_columnWeight">1</item>

        <item name="cornerRadius">36dp</item>
        <item name="background">@drawable/btn_pin_gradient</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textSize">22sp</item>
        <item name="elevation">6dp</item>
    </style>

    <style name="PinButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">72dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textSize">24sp</item>
        <item name="cornerRadius">36dp</item>
        <item name="background">@drawable/btn_pin_ripple</item>
    </style>
</resources>
